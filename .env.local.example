# Copy this file to .env.local and fill in your Supabase project values.
# Find them in Supabase: top "Connect" button, or Project Settings -> API.
# These are PUBLIC values, safe to expose in a browser app.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Use ONE of the following (whichever your Supabase dashboard shows):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...   # legacy anon key, also works
